import gymnasium as gym
import torch
import torch.nn as nn
import torch.optim as optim
import random

env = gym.make("CartPole-v1")

# Action mapping for clarity
ACTION_NAMES = {0: "Push Left", 1: "Push Right"}

class Net(nn.Module):
    def __init__(self):
        super().__init__()
        self.fc = nn.Sequential(nn.Linear(4, 64), nn.ReLU())
        self.v = nn.Linear(64, 1)   # State Value
        self.a = nn.Linear(64, 2)   # Action Advantage

    def forward(self, x):
        x = self.fc(x)
        v = self.v(x)
        a = self.a(x)
        # Standard Dueling combination formula
        return v + (a - a.mean(dim=-1, keepdim=True))

net = Net()
opt = optim.Adam(net.parameters(), lr=1e-3)

for ep in range(50):
    s, _ = env.reset()
    total = 0

    for step in range(200):
        s_t = torch.tensor(s, dtype=torch.float32)
        q = net(s_t)

        # Epsilon-greedy
        if random.random() < 0.1:
            a = env.action_space.sample()
        else:
            a = q.argmax().item()

        # Print the action name occasionally or for specific steps
        # print(f"Step {step}: Taking action {a} ({ACTION_NAMES[a]})")

        s2, r, done, trunc, _ = env.step(a)
        total += r

        # Compute Target
        with torch.no_grad():
            next_q = net(torch.tensor(s2, dtype=torch.float32))
            # If the episode ends, there is no future reward
            target = r + (0.99 * next_q.max() * (1 - int(done)))

        # LOSS FIX: Use q[a] specifically for the backprop path
        current_q_value = net(s_t)[a] 
        loss = (current_q_value - target) ** 2

        opt.zero_grad()
        loss.backward()
        opt.step()

        s = s2
        if done or trunc:
            # Print final action and result
            print(f"Episode {ep} ended. Last Action: {ACTION_NAMES[a]} | Total Reward: {total}")
            break
